# NL-BI Dashboard - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# 
# Required variables are marked with [REQUIRED]
# Optional variables have default values shown

# =============================================================================
# LLM Configuration (OpenAI-Compatible Endpoints) [REQUIRED]
# =============================================================================
# At least one of the following configurations must be set:
#
# Option A: Use OpenAI directly (Recommended for production)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Option B: Use a custom OpenAI-compatible endpoint
# These settings work with any OpenAI-compatible provider:
# - Ollama (local): http://localhost:11434/v1
# - LM Studio (local): http://localhost:1234/v1
# - vLLM (local): http://localhost:8000/v1
# - Groq (fast cloud): https://api.groq.com/openai/v1
# - Together AI (cloud): https://api.together.xyz/v1
# - Azure OpenAI: https://your-resource.openai.azure.com/
# - Any other OpenAI-compatible endpoint

# LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# =============================================================================
# LLM Model Settings [OPTIONAL]
# =============================================================================
# Override default model behavior
# LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=2000

# =============================================================================
# Security Settings [OPTIONAL]
# =============================================================================
# Rate limiting configuration
# MAX_QUERIES_PER_WINDOW=30
# RATE_LIMIT_WINDOW_MINUTES=5

# Row limit for query results
# MAX_ROWS_LIMIT=1000

# Input validation
# MAX_QUESTION_LENGTH=500
# MIN_QUESTION_LENGTH=5

# =============================================================================
# Database Settings [REQUIRED for PostgreSQL]
# =============================================================================
# Database type: 'sqlite' (default) or 'postgresql'
# DB_TYPE=sqlite

# PostgreSQL connection (for production deployment)
# Uncomment and fill in the following for PostgreSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nlbi_dashboard

# Read-only user (used by the application for queries)
# DB_USER=nlbi_readonly
# DB_PASSWORD=nlbi_readonly_secret_2024

# Admin credentials (used for schema creation and migrations)
# DB_ADMIN_USER=admin
# DB_ADMIN_PASSWORD=admin_secret_2024

# SSL mode: disable, allow, prefer, require, verify-ca, verify-full
# DB_SSL_MODE=prefer

# =============================================================================
# LangSmith Tracing (for debugging) [OPTIONAL]
# =============================================================================
# Enable LangSmith for debugging and tracing LLM calls
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langchain-api-key-here
# LANGCHAIN_PROJECT=nlbi-dashboard

# =============================================================================
# Example Configurations
# =============================================================================

# For Ollama (local LLM - Free, Private):
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# For Groq (fast cloud inference):
# LLM_API_KEY=gsk_your-groq-key-here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-70b-versatile

# For Together AI (open-source models):
# LLM_API_KEY=your-together-key-here
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3-70b-chat-hf

# For LM Studio (local with GUI):
# LLM_API_KEY=lm-studio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model

# For vLLM (high-performance local serving):
# LLM_API_KEY=vllm
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=auto

# For Azure OpenAI (enterprise):
# LLM_API_KEY=your-azure-key-here
# LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# LLM_MODEL=gpt-4o

# =============================================================================
# Security Best Practices
# =============================================================================
# 1. NEVER commit .env files to version control
# 2. Use strong, unique API keys
# 3. Rotate keys regularly
# 4. For production, use a secrets manager (HashiCorp Vault, AWS Secrets Manager)
# 5. Set appropriate file permissions: chmod 600 .env
