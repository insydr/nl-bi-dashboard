# NL-BI Dashboard - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (OpenAI-Compatible Endpoints)
# =============================================================================

# Option 1: Use OpenAI directly
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Option 2: Use a custom OpenAI-compatible endpoint
# These settings work with any OpenAI-compatible provider:
# - Ollama (local): http://localhost:11434/v1
# - LM Studio (local): http://localhost:1234/v1
# - vLLM (local): http://localhost:8000/v1
# - Groq: https://api.groq.com/openai/v1
# - Together AI: https://api.together.xyz/v1
# - Azure OpenAI: https://your-resource.openai.azure.com/
# - Any other OpenAI-compatible endpoint

# LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# =============================================================================
# Optional: LangSmith Tracing (for debugging)
# =============================================================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langchain-api-key-here
# LANGCHAIN_PROJECT=nlbi-dashboard

# =============================================================================
# Example Configurations
# =============================================================================

# For Ollama (local LLM):
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# For Groq (fast inference):
# LLM_API_KEY=gsk_xxxx
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-70b-versatile

# For Together AI:
# LLM_API_KEY=xxxx
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3-70b-chat-hf

# For LM Studio (local):
# LLM_API_KEY=lm-studio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model
